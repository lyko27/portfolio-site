---
import TimelineCard from './TimelineCard.astro';
import { educationEvents, experienceEvents } from '../data/portfolio.js';
import { useTranslations } from '../i18n/ui.js';

const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
---

<section 
    id="parcours" 
    class="py-20 lg:py-32 px-6 md:px-12 bg-white relative overflow-hidden"
>
    <div 
        class="absolute inset-0 pointer-events-none opacity-[0.05]" 
        style="background-image: linear-gradient(#233554 1.5px, transparent 1.5px), linear-gradient(90deg, #233554 1.5px, transparent 1.5px); background-size: 40px 40px;"
    >
    </div>

    <div class="max-w-4xl mx-auto text-center mb-16 relative z-10">
      <div 
        class="inline-block bg-blue-100 border-2 border-[#233554] px-4 py-1 rounded-lg shadow-[4px_4px_0px_0px_#233554] mb-4 transform -rotate-2"
      >
        <h2 class="text-[#233554] font-bold tracking-widest uppercase text-xs">
          {t('parcours.badge')}
        </h2>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#233554] mt-2">{t('parcours.title')}</h1>
    </div>

    <div class="max-w-4xl mx-auto relative z-10">
      <div class="flex flex-wrap justify-center gap-6 mb-16" role="tablist">
          <button 
            id="tab-education"
            class="relative px-8 py-3 rounded-xl border-2 border-blue-900 text-sm font-bold uppercase tracking-wider transition-all bg-blue-600 text-white shadow-[6px_6px_0px_0px_#1e3a8a] hover:-translate-y-1 active:translate-y-1 active:shadow-none"
            role="tab"
            aria-selected="true"
            aria-controls="content-education"
          >
            {t('parcours.edu')}
          </button>
          
          <button 
            id="tab-experience"
            class="relative px-8 py-3 rounded-xl border-2 border-emerald-900 text-sm font-bold uppercase tracking-wider transition-all bg-white text-emerald-700 shadow-[6px_6px_0px_0px_#064e3b] hover:-translate-y-1 active:translate-y-1 active:shadow-none"
            role="tab"
            aria-selected="false"
            aria-controls="content-experience"
          >
            {t('parcours.exp')}
          </button>
      </div>

      <div 
        id="timeline-wrapper" 
        class="relative w-full transition-all duration-300 ease-in-out"
      >
          <div 
            id="timeline-bar" 
            class="absolute left-[28px] md:left-[43px] top-4 bottom-4 w-1 bg-blue-100 border-r-2 border-dashed border-blue-300 transition-all duration-500 origin-top"
          ></div>

          <div 
            id="content-education" 
            class="tab-content transition-all duration-500 opacity-100 translate-y-0" 
            role="tabpanel" 
            aria-labelledby="tab-education"
          >
            <div class="flex flex-col gap-10">
              {educationEvents[lang].map((item) => (
                <TimelineCard item={item} theme="blue" />
              ))}
            </div>
          </div>

          <div 
            id="content-experience" 
            class="tab-content absolute top-0 left-0 w-full transition-all duration-500 opacity-0 translate-y-8 pointer-events-none invisible" 
            role="tabpanel" 
            aria-labelledby="tab-experience"
          >
            <div class="flex flex-col gap-10">
              {experienceEvents[lang].map((item) => (
                <TimelineCard item={item} theme="emerald" />
              ))}
            </div>
          </div>
      </div>
    </div>
</section>

<script>
  // Bascule entre les onglets Éducation et Expérience.
  const initTabs = () => {
    const tabEdu = document.getElementById('tab-education');
    const tabExp = document.getElementById('tab-experience');
    const contentEdu = document.getElementById('content-education');
    const contentExp = document.getElementById('content-experience');
    const wrapper = document.getElementById('timeline-wrapper');
    const timelineBar = document.getElementById('timeline-bar');

    if (!tabEdu || !tabExp || !contentEdu || !contentExp || !wrapper || !timelineBar) return;

    const styles = {
        edu: { active: ['bg-blue-600', 'text-white'], inactive: ['bg-white', 'text-blue-700'], bar: ['bg-blue-100', 'border-blue-300'] },
        exp: { active: ['bg-emerald-600', 'text-white'], inactive: ['bg-white', 'text-emerald-700'], bar: ['bg-emerald-100', 'border-emerald-300'] }
    };

    const switchTabs = (targetType) => {
        const isEdu = targetType === 'edu';
        const activeTab = isEdu ? tabEdu : tabExp;
        const inactiveTab = isEdu ? tabExp : tabEdu;
        const showContent = isEdu ? contentEdu : contentExp;
        const hideContent = isEdu ? contentExp : contentEdu;
        const currentStyle = isEdu ? styles.edu : styles.exp;
        const otherStyle = isEdu ? styles.exp : styles.edu;

        activeTab.classList.remove(...currentStyle.inactive);
        activeTab.classList.add(...currentStyle.active);
        activeTab.setAttribute('aria-selected', 'true');
        
        inactiveTab.classList.remove(...otherStyle.active);
        inactiveTab.classList.add(...otherStyle.inactive);
        inactiveTab.setAttribute('aria-selected', 'false');

        timelineBar.style.transform = 'scaleY(0)';
        wrapper.style.minHeight = `${wrapper.offsetHeight}px`;

        hideContent.classList.remove('opacity-100', 'translate-y-0');
        hideContent.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none', 'invisible', 'absolute');

        setTimeout(() => {
            timelineBar.className = `absolute left-[28px] md:left-[43px] top-4 bottom-4 w-1 border-r-2 border-dashed transition-all duration-500 origin-top ${currentStyle.bar.join(' ')}`;
            timelineBar.style.transform = 'scaleY(1)';
            showContent.classList.remove('absolute', 'opacity-0', 'translate-y-8', 'pointer-events-none', 'invisible');
            showContent.classList.add('opacity-100', 'translate-y-0');
            setTimeout(() => { wrapper.style.minHeight = ''; }, 500);
        }, 150);
    };

    tabEdu.addEventListener('click', () => { if (tabEdu.getAttribute('aria-selected') !== 'true') switchTabs('edu'); });
    tabExp.addEventListener('click', () => { if (tabExp.getAttribute('aria-selected') !== 'true') switchTabs('exp'); });
  };
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initTabs); } else { initTabs(); }
</script>