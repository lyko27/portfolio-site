---
import { useTranslations } from '../i18n/ui.js';

const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
---
<section id="contact" class="relative bg-[#fff9e6] text-[#233554] py-24 overflow-hidden">
    <div 
        class="absolute inset-0 z-0 opacity-40 pointer-events-none mix-blend-multiply" 
        style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.4'/%3E%3C/svg%3E&quot;);"
    ></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-12 mb-20">
            <div class="text-center md:text-left relative">
                <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight text-[#233554]">
                    {t('contact.title.1')} <br>
                    <span class="text-blue-600 relative inline-block">{t('contact.title.2')}<svg class="absolute w-full h-3 -bottom-1 left-0 text-yellow-300 -z-10" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="8" fill="none" /></svg></span>
                </h1>
                <p class="text-gray-600 text-lg max-w-md leading-relaxed" set:html={t('contact.subtitle')}>
                </p>
            </div>

            <div class="flex flex-col gap-4 w-full md:w-auto">
                <div 
                    id="email-card" 
                    class="group cursor-pointer bg-orange-50 border-2 border-[#233554] p-6 rounded-2xl flex items-center gap-6 transition-all hover:-translate-y-1 shadow-[6px_6px_0px_0px_#233554] hover:shadow-[8px_8px_0px_0px_#233554]"
                >
                    <div 
                        id="email-icon-container" 
                        class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-all border border-emerald-100"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-mailbox w-6 h-6" viewBox="0 0 16 16"><path d="M4 4a3 3 0 0 0-3 3v6h6V7a3 3 0 0 0-3-3m0-1h8a4 4 0 0 1 4 4v6a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V7a4 4 0 0 1 4-4m2.646 1A4 4 0 0 1 8 7v6h7V7a3 3 0 0 0-3-3z"/><path d="M11.793 8.5H9v-1h5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.354-.146zM5 7c0 .552-.448 0-1 0s-1 .552-1 0a1 1 0 0 1 2 0"/></svg>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">{t('contact.email.label')}</p>
                        <p id="email-display" class="text-xl font-bold text-[#233554]" data-success-text={t('contact.email.copied')}>nateo.gadaix@etu.isima.fr</p>
                    </div>
                    <div class="ml-auto opacity-0 group-hover:opacity-100 text-emerald-600 text-sm font-medium transition-opacity">{t('contact.email.copy')}</div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <a 
                        href="//www.linkedin.com/in/nat%C3%A9o-gadaix-7507a0383/" 
                        target="_blank" 
                        class="bg-orange-50 border-2 border-[#233554] p-4 rounded-2xl flex items-center justify-center gap-3 transition-all hover:-translate-y-1 shadow-[4px_4px_0px_0px_#233554] hover:shadow-[6px_6px_0px_0px_#233554] group"
                    >
                        <svg class="w-6 h-6 text-gray-400 group-hover:text-[#0077b5] transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                        <span class="font-bold text-[#233554]">LinkedIn</span>
                    </a>
                    <a 
                        href="https://github.com/lyko27" 
                        target="_blank" 
                        class="bg-orange-50 border-2 border-[#233554] p-4 rounded-2xl flex items-center justify-center gap-3 transition-all hover:-translate-y-1 shadow-[4px_4px_0px_0px_#233554] hover:shadow-[6px_6px_0px_0px_#233554] group"
                    >
                        <svg class="w-6 h-6 text-gray-400 group-hover:text-black transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.133 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                        <span class="font-bold text-[#233554]">GitHub</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="h-px w-full bg-gradient-to-r from-transparent via-[#233554]/20 to-transparent mb-12"></div>

        <div class="flex flex-col md:flex-row justify-between items-center gap-8 text-center md:text-left">
            <div class="max-w-xs">
                <a href="#home" class="block text-2xl font-bold text-[#233554] mb-2 hover:text-blue-600 transition-colors">&lt; Natéo /&gt;</a>
                <p class="text-gray-500 text-sm leading-relaxed" set:html={t('footer.dev')}>
                </p>
            </div>
            <div class="flex flex-col items-center md:items-end gap-4">
                <div class="flex gap-6">
                    <a href="#home" class="text-gray-500 hover:text-[#233554] text-sm font-medium transition-colors">{t('nav.home')}</a>
                    <a href="#projets" class="text-gray-500 hover:text-[#233554] text-sm font-medium transition-colors">{t('nav.projects')}</a>
                    <a href="https://instagram.com/nateo.gdx" target="_blank" class="text-gray-500 hover:text-pink-600 text-sm font-medium transition-colors flex items-center gap-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        Instagram
                    </a>
                </div>
                <div class="text-gray-400 text-xs">
                    © {new Date().getFullYear()} Natéo Gadaix. {t('footer.rights')}
                </div>
            </div>
        </div>
    </div>
</section>

<script>
  // Copie de l'adresse email dans le presse-papier avec retour visuel.
  document.addEventListener('DOMContentLoaded', () => {
    const emailCard = document.getElementById('email-card');
    const emailDisplay = document.getElementById('email-display');
    const emailIconContainer = document.getElementById('email-icon-container');
    const email = "nateo.gadaix@etu.isima.fr";
    
    const defaultIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-mailbox w-6 h-6" viewBox="0 0 16 16"><path d="M4 4a3 3 0 0 0-3 3v6h6V7a3 3 0 0 0-3-3m0-1h8a4 4 0 0 1 4 4v6a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V7a4 4 0 0 1 4-4m2.646 1A4 4 0 0 1 8 7v6h7V7a3 3 0 0 0-3-3z"/><path d="M11.793 8.5H9v-1h5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.354-.146zM5 7c0 .552-.448 0-1 0s-1 .552-1 0a1 1 0 0 1 2 0"/></svg>`;
    const successIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-mailbox-flag w-6 h-6" viewBox="0 0 16 16"><path d="M10.5 8.5V3.707l.854-.853A.5.5 0 0 0 11.5 2.5v-2A.5.5 0 0 0 11 0H9.5a.5.5 0 0 0-.5.5v8zM5 7c0 .334-.164.264-.415.157C4.42 7.087 4.218 7 4 7s-.42.086-.585.157C3.164 7.264 3 7.334 3 7a1 1 0 0 1 2 0"/><path d="M4 3h4v1H6.646A4 4 0 0 1 8 7v6h7V7a3 3 0 0 0-3-3V3a4 4 0 0 1 4 4v6a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V7a4 4 0 0 1 4-4m0 1a3 3 0 0 0-3 3v6h6V7a3 3 0 0 0-3-3"/></svg>`;

    if (emailCard && emailDisplay) {
        emailCard.addEventListener('click', () => {
            navigator.clipboard.writeText(email).then(() => {
                const originalText = emailDisplay.innerText;
                const successText = emailDisplay.getAttribute('data-success-text') || "Adresse copiée !";
                emailDisplay.innerText = successText;
                emailDisplay.classList.add('text-emerald-600');
                
                if (emailIconContainer) {
                    emailIconContainer.classList.add('bg-emerald-600', 'text-white');
                    emailIconContainer.classList.remove('bg-emerald-50', 'text-emerald-600');
                    emailIconContainer.style.transform = "rotate(-30deg)";
                    setTimeout(() => { emailIconContainer.innerHTML = successIcon; emailIconContainer.style.transform = "rotate(0deg)"; }, 300);
                }

                setTimeout(() => {
                    emailDisplay.innerText = originalText;
                    emailDisplay.classList.remove('text-emerald-600');
                    if (emailIconContainer) {
                        emailIconContainer.classList.remove('bg-emerald-600', 'text-white');
                        emailIconContainer.classList.add('bg-emerald-50', 'text-emerald-600');
                        emailIconContainer.style.transform = "rotate(30deg)";
                        setTimeout(() => { emailIconContainer.innerHTML = defaultIcon; emailIconContainer.style.transform = "rotate(0deg)"; }, 300);
                    }
                }, 3000);
            });
        });
    }
  });
</script>