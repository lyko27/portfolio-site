---
import { useTranslations } from '../i18n/ui.js';

const { project, lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
---

<div class="group relative bg-white border-2 border-[#233554] rounded-2xl overflow-hidden shadow-[6px_6px_0px_0px_#233554] hover:-translate-y-2 hover:shadow-[10px_10px_0px_0px_#233554] transition-all flex flex-col h-full">
    
    <div class={`border-b-2 border-[#233554] p-4 flex justify-between items-center ${project.color}`}>
        <span class="font-mono text-xs font-bold text-[#233554]/70 uppercase tracking-wider">
            PROJ-{project.year}
        </span>
        <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full border border-[#233554] bg-white"></div>
            <div class="w-2.5 h-2.5 rounded-full border border-[#233554] bg-white"></div>
        </div>
    </div>

    <div class="p-6 flex-grow flex flex-col">
        <h3 class="text-2xl font-extrabold text-[#233554] mb-3 group-hover:text-blue-600 transition-colors leading-tight">
            {project.title}
        </h3>
        <p class="text-gray-600 mb-6 line-clamp-4 flex-grow leading-relaxed text-sm">{project.desc}</p>

        <div class="flex flex-wrap gap-2 mb-6">
            {project.tags.map(tag => (
                <span class="px-2 py-1 text-[10px] font-bold border border-[#233554] rounded bg-white text-[#233554] uppercase tracking-wide shadow-[2px_2px_0px_0px_#233554]">
                    {tag}
                </span>
            ))}
        </div>

        <div class="flex items-center justify-between pt-4 border-t-2 border-dashed border-gray-200 mt-auto">
            <a 
                href={project.repo} 
                target="_blank" 
                class="flex items-center gap-2 text-xs font-bold text-gray-500 hover:text-[#233554] transition-colors uppercase tracking-wider"
            >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.133 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                {t('btn.code')}
            </a>
            <a 
                href={project.doc} 
                class="flex items-center gap-2 text-xs font-bold text-white bg-[#233554] px-3 py-2 rounded-lg shadow-[2px_2px_0px_0px_#64748b] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all uppercase tracking-wider"
            >
                {t('btn.doc')}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        </div>
    </div>
</div>