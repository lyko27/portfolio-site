---
import BaseLayout from '../../layouts/baseLayouts.astro';
import { useTranslations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang);
---

<BaseLayout title={`${t('journal.title')} - Natéo Gadaix`} lang={lang}>
  <section class="min-h-screen flex items-center justify-center bg-slate-50 relative overflow-hidden px-6">
    
    <!-- Background : Grille Technique -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 opacity-[0.03]" 
             style="background-image: linear-gradient(#233554 1px, transparent 1px), linear-gradient(90deg, #233554 1px, transparent 1px); background-size: 50px 50px;">
        </div>
    </div>

    <div class="max-w-2xl w-full relative z-10 text-center">
        
        <!-- Icône de Construction Style Blueprint -->
        <div class="w-24 h-24 mx-auto mb-8 bg-[#1e3a8a] rounded-2xl flex items-center justify-center shadow-[8px_8px_0px_0px_#233554] border-2 border-[#233554] transform -rotate-3 hover:rotate-0 transition-transform duration-500">
            <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
        </div>

        <!-- Badge Statut -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-100 text-orange-700 border border-orange-200 mb-6">
             <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
            </span>
            <span class="text-xs font-bold uppercase tracking-widest">{t('journal.badge')}</span>
        </div>

        <h1 class="text-4xl md:text-5xl font-extrabold text-[#233554] mb-6 leading-tight">
            {t('journal.title')}<br>
            <span class="text-blue-600">{t('journal.subtitle')}</span>
        </h1>

        <p class="text-lg text-gray-600 mb-10 leading-relaxed max-w-md mx-auto">
            {t('journal.desc')}
        </p>

        <div class="flex justify-center gap-4">
            <a href={`/${lang}/`} class="group px-8 py-3 bg-[#233554] text-white font-bold rounded-xl shadow-[4px_4px_0px_0px_#1e3a8a] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_0px_#1e3a8a] transition-all flex items-center gap-2">
                <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                {t('journal.back')}
            </a>
        </div>

    </div>

  </section>
</BaseLayout>